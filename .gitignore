# dependencies & build
node_modules
build
.svelte-kit
*.tsbuildinfo

# secrets - NEVER commit (.env.example is the template that IS committed)
.env
.env.*
!.env.example

# signing material - never, anywhere in the tree (Android keystores live under the
# generated native project, but the patterns guard against a stray copy too)
*.keystore
*.jks
*.p12
*.pem
key.properties

# database dumps / backups - user data must never reach the repo
*.dump
*.sql.gz
*.backup
backups/

# logs
*.log

# Capacitor NATIVE projects (generated by `npx cap add`; regenerate, don't commit).
# NB: /capacitor-shell itself IS committed - capacitor.config.ts points webDir at it
# and its two HTML files (redirect stub + offline error page) are hand-written source.
/android
/ios
.gradle

# the roadmap is the private planning document (strategy, consultant notes) - it stays
# with the maintainer, not in the public repo
ROADMAP.md

# packaged release zips
excogni-*.zip

# editor / OS noise
.DS_Store
.vscode/
.idea/
