# --- Database ---
DATABASE_URL=postgres://excogni:excogni@localhost:5432/excogni

# --- Feature flags ---
# Seeds ~120 simulated users with rating distributions, and INCLUDES them in percentile pools.
ENABLE_SIMULATED_USERS=true
# Renders the magic link directly on the login page after requesting it (dev convenience, no SMTP needed).
# In production set this to false and wire up SMTP in src/lib/server/auth/mail.ts.
DEV_EXPOSE_MAGIC_LINKS=true
# Shows debug surfaces (raw scores, pool internals, IDs). NEVER true in production.
SHOW_DEBUG_UI=true
# Includes simulated users in the public /statistics page (clearly labeled "preview"),
# so the page can be demoed before real consented users exist. NEVER true in production - # it would mix synthetic data into the real public picture. Off unless set.
STATS_PREVIEW=true


# --- App ---
ORIGIN=http://localhost:3000
PORT=3000

# --- Admin statistical tool (standalone, separate from the user app) ---
# Set a long random token to enable /admin. Leave blank to disable entirely.
# Access: sign in at /admin/login with the token (+ TOTP code if set below).
# This is NOT a user role - it is a separate, env-gated surface.
ADMIN_TOKEN=
# Strongly recommended in production: a second factor for admin login.
# Generate + verify: node --experimental-strip-types scripts/gen-totp-secret.mjs
# then add the same key to your authenticator app (TOTP, SHA1, 6 digits, 30s).
ADMIN_TOTP_SECRET=
# Hard floor: no group smaller than this is ever displayed (anti-identification).
ADMIN_MIN_CELL=20
# Public breakdowns are openly filterable/exportable, so a more conservative floor:
# any filtered group below this is withheld from the public /statistics page. >= admin floor.
PUBLIC_MIN_CELL=50

# --- Production email (SMTP) ---
# Required for real magic-link delivery. If SMTP_HOST is unset, links only go to
# stdout (dev). Use a transactional provider (Postmark, Resend, SES, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Excogni <no-reply@yourdomain.com>

# --- Blind email index (recommended in production) ---
# With this set (>=32 random chars, e.g. `openssl rand -base64 48`), the readable login
# email is NEVER stored - only a keyed one-way index + a masked hint. BACK THIS KEY UP
# like a database password: losing it means existing hashed emails stop matching and
# those accounts cannot log in. After first setting it, run once:
#   node scripts/backfill-email-hash.mjs
# Leave blank for the legacy plaintext behavior (dev default).
EMAIL_INDEX_KEY=

# --- Production secrets (used by docker-compose.prod.yml) ---
# POSTGRES_PASSWORD=change-me-to-a-long-random-string
# ORIGIN=https://yourdomain.com
ENABLE_CIRCLES=false   # set true to turn on Practice Circles (the social feature)

# Local testing of a production build over plain http only - NEVER on a server.
# Without it the Secure session cookie is dropped and every request is a new user.
# INSECURE_COOKIES=1
