# Keep the Docker build context small and free of local/secret/native files.
node_modules
build
.svelte-kit
.git
.gitignore

# never copy local env/secrets into an image
.env
.env.*
!.env.example

# logs
*.log

# Capacitor native projects (generated locally, not needed in the server image)
android
ios
capacitor-shell
.gradle

# editor / OS noise
.DS_Store
.vscode
.idea

# the packaged release zips
excogni-*.zip
